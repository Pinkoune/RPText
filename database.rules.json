{
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "chat": {
      ".write": "auth != null",
      "global": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$msg": {
          ".validate": "newData.hasChildren(['uid', 'name', 'text', 'ts']) && newData.child('text').isString() && newData.child('text').val().length <= 240"
        }
      },
      "team": {
        "$teamId": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$msg": {
            ".validate": "newData.hasChildren(['uid', 'name', 'text', 'ts']) && newData.child('text').isString() && newData.child('text').val().length <= 240"
          }
        }
      },
      "guild": {
        "$guildId": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$msg": {
            ".validate": "newData.hasChildren(['uid', 'name', 'text', 'ts']) && newData.child('text').isString() && newData.child('text').val().length <= 240"
          }
        }
      },
      "inbox": {
        "$recipientName": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$msg": {
            ".validate": "newData.hasChildren(['uid', 'name', 'text', 'ts']) && newData.child('text').isString() && newData.child('text').val().length <= 240"
          }
        }
      }
    },
    "world": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "dungeons": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "endlessSessions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "pvpDuels": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
