# Firebase — copie ce fichier en .env.local et remplis avec les valeurs
# de ta console Firebase : Paramètres du projet > Tes applications > Config SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# URL de la Realtime Database (présence/multijoueur), ex:
# https://ton-projet-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_DATABASE_URL=
